# OpenRouter API key (required for adaptive mode attacker LLM)
OPENROUTER_API_KEY=your_openrouter_key_here

# Backend selection: "local" or "daytona"
CRACKER_BACKEND=local

# Attacker model configuration (OpenRouter format, adaptive mode only)
ATTACKER_MODEL=qwen/qwen3-30b-a3b-instruct-2507
ATTACKER_MAX_TURNS=5

# Local backend configuration
AGENT_ID=main

# Daytona backend configuration (only needed if using Daytona)
DAYTONA_API_KEY=your_daytona_key
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_IMAGE=node:22-bookworm
MODEL_UNDER_TEST=moonshotai/kimi-k2.5
